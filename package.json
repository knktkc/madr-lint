{
  "name": "madr-lint",
  "version": "0.1.0-alpha.0",
  "description": "A linter for MADR (Markdown Architectural Decision Records) — structure, numbering, status, supersedes integrity",
  "type": "module",
  "private": true,
  "bin": {
    "madr-lint": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests"
  },
  "keywords": [
    "madr",
    "adr",
    "lint",
    "linter",
    "architecture-decision-records",
    "markdown"
  ],
  "license": "MIT",
  "author": "t.kaneko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knktkc/madr-lint.git"
  },
  "bugs": {
    "url": "https://github.com/knktkc/madr-lint/issues"
  },
  "homepage": "https://github.com/knktkc/madr-lint#readme",
  "dependencies": {
    "ajv": "^8.20.0",
    "citty": "^0.2.2",
    "gray-matter": "^4.0.3",
    "mdast-util-from-markdown": "^2.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "safe-regex2": "^5.1.1",
    "tinybench": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
