{
  "name": "madr-lint",
  "version": "0.4.0",
  "description": "Linter for MADR (Markdown Architectural Decision Records) — supports v2 bold-list and v3/v4 frontmatter. Validates filename pattern, required sections, status enum, ISO 8601 dates, numbering uniqueness/gaps, supersedes bidirectionality, and inter-ADR link integrity.",
  "type": "module",
  "bin": {
    "madr-lint": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src tests",
    "perf:check": "tsx scripts/perf-regression-check.ts",
    "redos": "tsx scripts/redos-scan.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "publish-ci": "changeset publish"
  },
  "keywords": [
    "madr",
    "madr-v2",
    "madr-v3",
    "madr-v4",
    "adr",
    "architecture",
    "architecture-decision-records",
    "decision-records",
    "lint",
    "linter",
    "markdown",
    "markdown-lint",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "author": "t.kaneko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knktkc/madr-lint.git"
  },
  "bugs": {
    "url": "https://github.com/knktkc/madr-lint/issues"
  },
  "homepage": "https://github.com/knktkc/madr-lint#readme",
  "dependencies": {
    "ajv": "^8.20.0",
    "citty": "^0.2.2",
    "gray-matter": "^4.0.3",
    "jiti": "^2.7.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-string": "^4.0.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.5",
    "safe-regex2": "^5.1.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.0",
    "@types/picomatch": "^4.0.3",
    "fast-check": "^4.8.0",
    "oxlint": "^1.72.0",
    "tinybench": "^6.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
