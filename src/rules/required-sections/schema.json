{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "sections": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required heading texts. Order does not matter."
    },
    "matchMode": {
      "type": "string",
      "enum": ["exact", "startsWith"],
      "description": "Comparison mode against heading text."
    }
  }
}
