{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "values": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Exact-match allowed status values."
    },
    "prefixValues": {
      "type": "array",
      "items": { "type": "string" },
      "description": "startsWith-match allowed prefixes (e.g. 'superseded by')."
    },
    "caseSensitive": {
      "type": "boolean",
      "description": "When false, comparisons are case-insensitive."
    }
  }
}
